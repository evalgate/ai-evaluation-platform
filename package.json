{
	"name": "ai-evaluation-platform",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"analyze": "ANALYZE=true next build",
		"build": "next build",
		"dev": "next dev",
		"typecheck": "tsc --noEmit",
		"dev:all": "concurrently \"pnpm dev\" \"pnpm dev:sdk\" --names \"app,sdk\" --prefix-colors \"blue,green\"",
		"dev:sdk": "cd src/packages/sdk && pnpm dev",
		"lint": "biome check .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"start": "next start",
		"test": "pnpm test:unit && pnpm test:db && pnpm test:dom",
		"test:run": "pnpm test:unit && pnpm test:db && pnpm test:dom",
		"test:unit": "vitest run -c vitest.unit.config.ts",
		"test:unit:coverage": "vitest run -c vitest.unit.config.ts --coverage",
		"test:db": "vitest run -c vitest.db.config.ts",
		"test:db:coverage": "vitest run -c vitest.db.config.ts --coverage",
		"test:dom": "vitest run -c vitest.dom.config.ts",
		"test:dom:coverage": "vitest run -c vitest.dom.config.ts --coverage",
		"test:coverage": "pnpm -s test:unit:coverage && pnpm -s test:dom:coverage && pnpm -s test:db:coverage",
		"test:confidence": "npx tsx scripts/run-confidence.ts",
		"test:coverage:gate": "vitest run --coverage --reporter=verbose --run --config vitest.gate.config.ts",
		"test:db-setup": "npx tsx scripts/test-db-setup.ts",
		"test:ui": "vitest --ui",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"sdk:build": "cd src/packages/sdk && pnpm build",
		"sdk:test": "cd src/packages/sdk && pnpm test",
		"remotion:preview": "npx remotion preview src/remotion/index.ts",
		"remotion:render": "npx remotion render src/remotion/index.ts DemoVideo out/demo-video.mp4",
		"db:migrate": "pnpm exec tsx scripts/run-migrations.ts",
		"db:migrate:new": "pnpm exec tsx scripts/run-migrations.ts 0037",
		"db:migrate-share-links": "pnpm exec tsx scripts/migrate-share-links-to-db.ts",
		"audit:openapi": "npx tsx scripts/audit-openapi-coverage.ts && npx tsx scripts/audit-openapi-spec.ts",
		"openapi:snapshot": "npx tsx scripts/openapi-snapshot.ts",
		"version:spec": "npx tsx scripts/version-spec.ts",
		"version:check": "npx tsx scripts/version-check.ts",
		"audit:coverage": "npx tsx scripts/coverage-audit.ts",
		"audit:demo-assets": "npx tsx scripts/audit-demo-assets.ts",
		"create:demo-placeholders": "npx tsx scripts/create-demo-placeholders.ts",
		"audit:determinism": "pnpm sdk:build && npx tsx scripts/audit-determinism.ts",
		"audit:performance": "npx tsx scripts/audit-performance.ts",
		"audit:retention": "npx tsx scripts/audit-retention.ts",
		"audit:migrations": "npx tsx scripts/audit-migrations.ts",
		"audit:indexes": "npx tsx scripts/index-audit.ts",
		"eval:golden": "pnpm sdk:build && npx tsx scripts/run-golden-eval.ts",
		"eval:regression-gate": "npx tsx scripts/regression-gate.ts",
		"eval:baseline-update": "npx tsx scripts/regression-gate.ts update",
		"eval:baseline-init": "npx tsx scripts/baseline-init.ts",
		"eval:latency-benchmark": "npx tsx scripts/latency-benchmark.ts",
		"openapi:generate-paths": "npx tsx scripts/generate-openapi-paths.ts",
		"release:preflight": "npx tsx scripts/release-preflight.ts",
		"ci:local": "npx tsx scripts/run-platform-ci.ts",
		"prepare": "husky || true"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,md}": [
			"biome check --write",
			"biome format --write"
		]
	},
	"dependencies": {
		"@babel/parser": "^7.29.0",
