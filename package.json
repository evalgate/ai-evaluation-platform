    "clsx": "^2.1.1",
    "cmdk": "1.0.4",
    "commander": "^14.0.1",
    "date-fns": "4.1.0",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.44.6",
    "embla-carousel-react": "8.5.1",
    "estree-walker": "2.0.2",
    "framer-motion": "^12.23.24",
    "geist": "^1.5.1",
