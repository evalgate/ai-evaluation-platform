# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules

# next.js
/.next/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local
!.env.example
!**/.env.example

# vercel
.vercel

# local sqlite (dev)
local.db

# test sqlite (vitest)
test.db

# coverage (vitest)
coverage

# npm auth (contains tokens)
**/.npmrc

# typescript
*.tsbuildinfo
next-env.d.ts
# Sentry Config File
.env.sentry-build-plugin

# Cursor rules (local)
.cursor/rules/

# SDK local config (created by evalai init)
src/packages/sdk/evalai.config.json

# npm pack artifact
*.tgz

# Golden eval CI artifact (generated by pnpm eval:golden)
evals/golden/golden-results.json

# Regression gate CI artifacts (generated by scripts)
evals/regression-report.json
evals/confidence-summary.json
evals/latency-benchmark.json
