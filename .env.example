# ===========================================
# AI Evaluation Platform — Environment Variables
# ===========================================
#
# ENV FILE STRATEGY:
#   .env          — Safe non-secret defaults (committed to git)
#   .env.local    — ALL secrets (gitignored, never committed)
#   Vercel UI     — Production secrets (must match .env.local secrets)
#
# Copy this file to .env.local and fill in the secret values.
# IMPORTANT: BETTER_AUTH_SECRET must be identical in .env.local AND Vercel
# so sessions in the shared Turso DB are valid across both environments.
#
# ===========================================

# ---------- Database (Turso / LibSQL) ----------
TURSO_CONNECTION_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ---------- Authentication (better-auth) ----------
# Secret MUST match across local + Vercel for shared session validity
BETTER_AUTH_SECRET=generate-a-random-secret-here
# Local: http://localhost:3000  |  Vercel: https://your-app.vercel.app
BETTER_AUTH_BASE_URL=http://localhost:3000

# ---------- GitHub OAuth (create at github.com/settings/apps) ----------
GITHUB_CLIENT_ID=your-github-app-client-id
GITHUB_CLIENT_SECRET=your-github-app-client-secret

# ---------- Google OAuth (create at console.cloud.google.com/apis/credentials) ----------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---------- Rate Limiting (Upstash Redis) ----------
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ---------- Billing (Autumn.js) ----------
AUTUMN_SECRET_KEY=am_sk_live_your-key-here
AUTUMN_PRODUCTION_SECRET_KEY=am_sk_live_your-key-here

# ---------- Payments (Stripe) ----------
STRIPE_LIVE_KEY=sk_live_your-stripe-key

# ---------- Error Monitoring (Sentry) ----------
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# ---------- LLM Providers (optional, for LLM Judge) ----------
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
