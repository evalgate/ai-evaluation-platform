{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": "./src",
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "types": ["node", "react", "react-dom"],
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/types/**/*.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/packages/sdk/**/*",
    "src/integrations/**/*",
    "src/remotion/**/*",
    "src/app/docs/**/*",
    "examples/**/*",
    "scripts/**/*",
    "src/__tests__/**/*",
    "**/__tests__/**/*",
    "tests/**/*",
    ".next/types/**/*"
  ]
}
