[
	{
		"intent": "Write a function that reverses a string",
		"expectedSignature": "reverseString(s)",
		"assertions": [
			{ "input": ["hello"], "expected": "olleh" },
			{ "input": [""], "expected": "" },
			{ "input": ["a"], "expected": "a" },
			{ "input": ["racecar"], "expected": "racecar" }
		]
	},
	{
		"intent": "Write a function that checks if a number is prime",
		"expectedSignature": "isPrime(n)",
		"assertions": [
			{ "input": [2], "expected": true },
			{ "input": [1], "expected": false },
			{ "input": [17], "expected": true },
			{ "input": [4], "expected": false },
			{ "input": [0], "expected": false }
		]
	},
	{
		"intent": "Write a function that flattens a nested array",
		"expectedSignature": "flatten(arr)",
		"assertions": [
			{ "input": [[[1, [2, 3]], [4]]], "expected": [1, 2, 3, 4] },
			{ "input": [[1, 2, 3]], "expected": [1, 2, 3] },
			{ "input": [[]], "expected": [] }
		]
	}
]
